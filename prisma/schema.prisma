generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Story {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String
  content     String
  cover       String
  music       String?
  createdAt   DateTime @default(now())
}

model Character {
  id Int @id @default(autoincrement())

  name String?

  slug String @unique

  title String?

  description String?

  image String?

  kingdom String?

  race String?

  status String?

  universe String?

  quote String?

  music String?

  profileStyle String @default("royal")

  images CharacterImage[]

  musics CharacterMusic[]

  createdAt DateTime @default(now())
}

model CharacterImage {
  id Int @id @default(autoincrement())

  image String

  sortOrder Int @default(0)

  characterId Int

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model CharacterMusic {
  id Int @id @default(autoincrement())

  name String?

  file String

  characterId Int

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Music {
  id Int @id @default(autoincrement())

  name String

  file String

  createdAt DateTime @default(now())
}

model Media {
  id Int @id @default(autoincrement())

  name String

  path String

  type String

  createdAt DateTime @default(now())
}